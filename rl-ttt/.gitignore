# Virtual environment
.venv/
venv/
env/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Pytest / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Distribution / packaging
*.egg-info/
build/
dist/

# Training artifacts (large binaries; metrics are kept as committed RESULTS.md)
artifacts/*
!artifacts/.gitkeep

# Exported Q-table for the web UI (regenerate via `python -m rl_ttt export`)
web/qtable.js

# Q-state animation data (regenerate via `python scripts/log_qstate.py`)
web/qstate-data.json

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
